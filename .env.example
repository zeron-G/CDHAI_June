# Copy to .env or export these variables in your shell.
# Do not commit real credentials or patient-identifiable data.

# LLM provider:
#   mock              - deterministic local draft mode
#   codex_oauth       - local Codex ChatGPT OAuth session
#   openai_compatible - OpenAI-compatible /responses endpoint
CDHAI_LLM_PROVIDER=mock
CDHAI_LLM_MODEL=gpt-4o-mini

# Optional Codex OAuth auth file. Defaults to ~/.codex/auth.json when blank.
CDHAI_CODEX_AUTH_PATH=

# Optional OpenAI-compatible endpoint settings.
CDHAI_OPENAI_BASE_URL=https://api.openai.com/v1
CDHAI_OPENAI_API_KEY=

# Local paths to adjacent CDHAI projects.
CDHAI_WELLDOC_SPACE_PATH=../WellDoc-SPACE
CDHAI_TOOLS_PATH=../WellDoc-SPACE/Tools
CDHAI_CODEX_OAUTH_PACKAGE_PATH=../HAI-Agent/packages/codex-oauth

# JHU database access. Use the JHU VPN and SSH agent/password entry at runtime.
# Never store the password here.
CDHAI_DB_SSH_HOST=10.175.198.65
CDHAI_DB_SSH_USER=rgao28
CDHAI_DB_SSH_PORT=22
CDHAI_DB_SSH_KEY_PATH=
CDHAI_DB_TUNNEL_LOCAL_PORT=15432
CDHAI_DB_REMOTE_HOST=127.0.0.1
CDHAI_DB_REMOTE_PORT=5432
CDHAI_DB_NAME=
CDHAI_DB_USER=
CDHAI_DB_PASSWORD=
